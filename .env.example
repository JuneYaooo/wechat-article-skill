# ============================================================================
# wechat-article-skill -- 环境变量（写作模式不需要，仅在发布到公众号草稿才需要）
# ============================================================================
#
# 写作模式（wechat-write）只用 Claude 内置工具，不需要任何 key。
# 下面的变量只在你要把文章上传到公众号草稿箱（wechat-publish 模式）时才需要。
#
# ============================================================================

# ---- 必填：公众号凭证（仅上传草稿时用）------------------------------------
# 来源：公众号后台 → 设置与开发 → 基本配置 → 开发者 ID(AppID) / 开发者密码(AppSecret)
#
# ⚠️ 安全警告：
# - AppSecret 一旦泄露可被冒用发文、改素材库，请只写在此处，不要提交到 git
# - 本仓库的 .gitignore 已默认忽略 .env
# - 不要把 AppSecret 粘到任何 issue / 公开对话 / 日志输出中
# - 公众号后台配置白名单 IP 可进一步降低风险

WECHAT_APP_ID=wx_your_app_id_here
WECHAT_APP_SECRET=your_app_secret_here

# ---- 可选：作者名（写进草稿的 author 字段）--------------------------------
# WECHAT_DEFAULT_AUTHOR=

# ---- 可选：text-to-image 服务 ---------------------------------------------
# scripts/generate_image.py 按下列顺序尝试，任一组填齐即可：
#   1. gpt-image-2   via  JULING_BASE_URL / JULING_API_KEY
#   2. nano-banana   via  NANO_BANANA_BASE_URL / NANO_BANANA_API_KEY
#   3. jimeng-4.0    via  JIMENG4_BASE_URL / JIMENG4_API_KEY
# 都不填则跳过自动生图，需要封面/配图时由你手动准备。

# JULING_BASE_URL=https://your-juling-relay.example.com
# JULING_API_KEY=sk-...

# NANO_BANANA_BASE_URL=https://your-nano-banana-relay.example.com
# NANO_BANANA_API_KEY=sk-...

# JIMENG4_BASE_URL=https://your-jimeng-relay.example.com
# JIMENG4_API_KEY=sk-...

# ---- 可选：图床（如果你的渲染器需要外链图片 URL 而非本地路径）------------
# OSS_ENDPOINT=
# OSS_BUCKET=
# OSS_ACCESS_KEY_ID=
# OSS_ACCESS_KEY_SECRET=
